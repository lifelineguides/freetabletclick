---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const pageUrl = "https://freetablet.click/safelink-wireless";
const siteUrl = "https://freetablet.click/";
const pageTitle = "SafeLink Wireless Lifeline Review | Phone, BYOP, Eligibility Guide 2026";
const pageDescription =
  "Review SafeLink Wireless Lifeline service, bring-your-own-phone options, eligibility rules, and safer application steps. Device availability varies by state and current offers.";

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": `${siteUrl}#website` },
      "about": [
        { "@type": "Thing", "name": "SafeLink Wireless" },
        { "@type": "Thing", "name": "Lifeline Program" },
        { "@type": "Thing", "name": "Bring Your Own Phone" }
      ],
      "inLanguage": "en-US"
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What network does SafeLink Wireless use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SafeLink is a TracFone brand and service details can vary by device and market. Coverage and compatibility should always be checked before enrollment."
          }
        },
        {
          "@type": "Question",
          "name": "Can I bring my own phone to SafeLink?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SafeLink supports a bring-your-own-phone option for many compatible unlocked devices."
          }
        },
        {
          "@type": "Question",
          "name": "Does SafeLink offer free tablets?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "SafeLink mainly promotes phone service. Device availability beyond standard phone service can vary by state, stock, and current offer terms."
          }
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      "url": siteUrl,
      "name": "FreeTablet.click",
      "inLanguage": "en-US"
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  
  <main id="main-content" class="w-full flex-1 flex flex-col items-center">
    
    <!-- ==========================================
         SECTION 1: PREMIUM HERO
    =========================================== -->
    <section class="relative w-full flex flex-col items-center justify-center overflow-hidden bg-[#0f172a] text-white pt-20 pb-32 lg:pt-28 lg:pb-40" style="background-image: radial-gradient(circle at top right, rgba(16, 185, 129, 0.15), transparent 45%), radial-gradient(circle at bottom left, rgba(37, 99, 235, 0.2), transparent 45%);">
      <div class="relative z-10 mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        
        <!-- Trust Badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-semibold text-emerald-100 mb-6 shadow-sm">
          <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>FCC Authorized Lifeline Provider</span>
        </div>

        <!-- H1 Headline -->
        <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl text-white mb-6">
          SafeLink Wireless <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-blue-300">Free Phone & Tablet Program</span>
        </h1>
        
        <!-- Subtitle -->
        <p class="text-lg text-blue-100 sm:text-xl leading-relaxed font-medium max-w-3xl mx-auto mb-10">
          Review SafeLink Wireless Lifeline service, bring-your-own-phone options, and application basics. Phone service is the core offer, while device availability and other promotions can vary by state and current terms.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
          <a href="https://www.safelinkwireless.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-lg bg-emerald-600 px-8 py-4 text-lg font-bold text-white shadow-xl hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500 transition-all duration-300 transform hover:-translate-y-1 w-full sm:w-auto group">
            Apply Now on Official Site
            <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/eligibility" class="inline-flex items-center justify-center rounded-lg border border-white/30 bg-white/5 backdrop-blur-sm px-8 py-4 text-lg font-bold text-white hover:bg-white/10 transition-all duration-300 w-full sm:w-auto">
            Check Eligibility First
          </a>
        </div>

      </div>
    </section>

    <!-- ==========================================
         SECTION 2: QUICK OVERVIEW & INTERNAL SUPPORT
    =========================================== -->
    <section class="relative w-full bg-muted/30 pb-16 lg:pb-24" style="content-visibility: auto;">
      <div class="relative z-20 mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 -mt-16 sm:-mt-20 mb-8">
        <div class="bg-white rounded-2xl p-6 sm:p-10 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.1)] border border-border">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <span class="text-sm font-bold text-foreground/50 uppercase tracking-wider mb-2 block">Quick Provider Snapshot</span>
              <p class="text-foreground/80 font-medium leading-relaxed">
                SafeLink is a Lifeline-supported service. Plan details, device offers, support paths, and compatibility can vary by device, state, and current offer terms.
              </p>
            </div>
            <div>
              <span class="text-sm font-bold text-foreground/50 uppercase tracking-wider mb-2 block">Best Next Step</span>
              <p class="text-foreground/80 font-medium leading-relaxed">
                Confirm eligibility first, then compare SafeLink with the homepage guide and other provider pages before choosing your final route.
              </p>
            </div>
            <div>
              <span class="text-sm font-bold text-foreground/50 uppercase tracking-wider mb-2 block">Useful Internal Links</span>
              <div class="flex flex-wrap gap-2">
                <a href="/" class="px-3 py-2 rounded-lg bg-emerald-50 text-emerald-700 text-sm font-bold hover:bg-emerald-100 transition-colors">Homepage</a>
                <a href="/eligibility" class="px-3 py-2 rounded-lg bg-emerald-50 text-emerald-700 text-sm font-bold hover:bg-emerald-100 transition-colors">Eligibility</a>
                <a href="/how-to-apply" class="px-3 py-2 rounded-lg bg-emerald-50 text-emerald-700 text-sm font-bold hover:bg-emerald-100 transition-colors">How to Apply</a>
                <a href="/states" class="px-3 py-2 rounded-lg bg-emerald-50 text-emerald-700 text-sm font-bold hover:bg-emerald-100 transition-colors">States</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 3: WHAT MAKES SAFELINK DIFFERENT?
    =========================================== -->
    <section class="relative w-full py-16 bg-white border-t border-border">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            What Does SafeLink Wireless Offer?
          </h2>
          <p class="text-lg text-foreground/75 leading-relaxed">
            As a brand under TracFone Wireless (now part of Verizon), SafeLink is one of the oldest and most established Lifeline providers in the country, known for unmatched network quality.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          
          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-emerald-300 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-6">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">Nationwide Coverage</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              SafeLink is a long-running Lifeline brand, and coverage can be strong in many areas. Actual service quality still depends on your device, ZIP code, local congestion, and current network setup.
            </p>
          </div>

          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-emerald-300 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-6">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">Bring Your Own Phone</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              If your current phone is unlocked and compatible, SafeLink may let you keep using it instead of switching devices. Always check compatibility before you enroll.
            </p>
          </div>

          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-emerald-300 transition-colors relative overflow-hidden">
            <div class="absolute top-0 right-0 bg-emerald-100 text-emerald-800 text-[10px] font-bold px-3 py-1 rounded-bl-lg uppercase tracking-wider">Device Options</div>
            <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-6 mt-2">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">Phones & Tablets</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              Phone service is the main offer. Other device availability can vary by state, inventory, and current terms, so avoid assuming a specific tablet or premium device will be available.
            </p>
          </div>

          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-emerald-300 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-6">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">No Contracts or Bills</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              Lifeline service generally avoids long-term contracts and standard monthly bills, but you should still review current service terms, device terms, and replacement costs before enrolling.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 4: HOW TO QUALIFY
    =========================================== -->
    <section class="relative w-full py-16 lg:py-24 bg-slate-50 border-t border-border" style="content-visibility: auto;">
      <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            How to Qualify for SafeLink Wireless
          </h2>
          <p class="text-lg text-foreground/75 leading-relaxed">
            Because SafeLink is an authorized Lifeline provider, enrollment follows standard federal Lifeline rules. Review income or program qualification carefully before applying.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          
          <!-- Income Based -->
          <div class="bg-white rounded-2xl border border-border p-8 shadow-sm">
            <div class="flex items-center gap-4 mb-6 border-b border-border pb-4">
              <div class="w-10 h-10 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <h3 class="text-xl font-bold text-foreground">Income-Based Qualification</h3>
            </div>
            <p class="text-foreground/75 leading-relaxed font-medium mb-6">
              You are eligible if your household income is at or below <strong>135% of the Federal Poverty Guidelines</strong>.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Requires official proof of income (such as a prior year's tax return).
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Income thresholds adjust based on the number of people living in your household.
              </li>
            </ul>
          </div>

          <!-- Program Based -->
          <div class="bg-white rounded-2xl border border-border p-8 shadow-sm">
            <div class="flex items-center gap-4 mb-6 border-b border-border pb-4">
              <div class="w-10 h-10 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              </div>
              <h3 class="text-xl font-bold text-foreground">Program-Based Qualification</h3>
            </div>
            <p class="text-foreground/75 leading-relaxed font-medium mb-6">
              You bypass income checks entirely if you currently participate in federal programs such as:
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                SNAP (Supplemental Nutrition Assistance Program / EBT)
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Medicaid
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Supplemental Security Income (SSI)
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Veterans Pension and Survivors Benefit
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Federal Public Housing Assistance (FPHA)
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 5: OFFICIAL CONTACT INFORMATION
    =========================================== -->
    <section class="relative w-full py-12 lg:py-16 bg-white border-t border-border">
      <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
        
        <div class="bg-slate-900 rounded-3xl p-8 sm:p-10 text-white shadow-xl flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
          <div class="absolute inset-0 z-0 bg-gradient-to-r from-emerald-600/20 to-transparent pointer-events-none"></div>
          
          <div class="max-w-lg text-center md:text-left relative z-10">
            <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-bold uppercase tracking-wider mb-4 border border-white/20">
              <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Official Contact Info
            </div>
            <h2 class="text-2xl sm:text-3xl font-extrabold mb-4">Verify Your SafeLink Status</h2>
            <p class="text-slate-300 font-medium leading-relaxed m-0">
              We offer independent educational guides to help you apply. For specific questions regarding an existing application, activation help, or device shipping status, please reach out to SafeLink Wireless support directly.
            </p>
          </div>

          <div class="flex flex-col gap-4 w-full md:w-auto shrink-0 relative z-10">
            <a href="tel:18007233546" class="flex items-center justify-center gap-3 bg-emerald-600 text-white px-6 py-4 rounded-xl font-bold hover:bg-emerald-500 transition-colors shadow-md">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              1-800-378-1684
            </a>
            <a href="https://www.safelinkwireless.com/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 bg-white text-slate-900 px-6 py-4 rounded-xl font-bold hover:bg-slate-100 transition-colors shadow-md">
              <svg class="w-5 h-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
              safelinkwireless.com
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- ==========================================
         SECTION 6: PROVIDER FAQ
    =========================================== -->
    <section class="relative w-full py-16 lg:py-24 bg-muted/30 border-t border-border" style="content-visibility: auto;">
      <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            SafeLink Wireless FAQ
          </h2>
        </div>

        <div class="space-y-4">
          
          <details class="group bg-white border border-border rounded-xl overflow-hidden shadow-sm [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-foreground hover:bg-muted/50 transition-colors text-lg">
              What network does SafeLink Wireless use?
              <span class="transition duration-300 group-open:-rotate-180 text-emerald-600 shrink-0 ml-4">
                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="24" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="text-foreground/75 p-6 pt-0 leading-relaxed font-medium border-t border-border mt-2">
              SafeLink is part of the TracFone family, and coverage can vary by device and market. Check compatibility and local service expectations before you enroll.
            </div>
          </details>

          <details class="group bg-white border border-border rounded-xl overflow-hidden shadow-sm [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-foreground hover:bg-muted/50 transition-colors text-lg">
              Can I bring my own phone to SafeLink?
              <span class="transition duration-300 group-open:-rotate-180 text-emerald-600 shrink-0 ml-4">
                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="24" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="text-foreground/75 p-6 pt-0 leading-relaxed font-medium border-t border-border mt-2">
              Yes. SafeLink supports a bring-your-own-phone option for many compatible unlocked devices. Compatibility and setup requirements should be checked before enrollment.
            </div>
          </details>

          <details class="group bg-white border border-border rounded-xl overflow-hidden shadow-sm [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-foreground hover:bg-muted/50 transition-colors text-lg">
