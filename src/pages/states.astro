---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const pageUrl = "https://freetablet.click/states/";
const siteUrl = "https://freetablet.click/";
const pageTitle = "Free Government Tablet Programs by State | 2026 Directory";
const pageDescription =
  "Use this 2026 state directory to review location-based free government tablet information, compare approved Lifeline resources, and move into the right eligibility and application pages.";

// Complete 50-State Array for the A-Z Directory
const allStates = [
  "Alabama", "Alaska", "Arizona", "Arkansas", "California", "Colorado",
  "Connecticut", "Delaware", "Florida", "Georgia", "Hawaii", "Idaho",
  "Illinois", "Indiana", "Iowa", "Kansas", "Kentucky", "Louisiana",
  "Maine", "Maryland", "Massachusetts", "Michigan", "Minnesota",
  "Mississippi", "Missouri", "Montana", "Nebraska", "Nevada",
  "New Hampshire", "New Jersey", "New Mexico", "New York",
  "North Carolina", "North Dakota", "Ohio", "Oklahoma", "Oregon",
  "Pennsylvania", "Rhode Island", "South Carolina", "South Dakota",
  "Tennessee", "Texas", "Utah", "Vermont", "Virginia", "Washington",
  "West Virginia", "Wisconsin", "Wyoming"
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": `${siteUrl}#website` },
      "inLanguage": "en-US"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "States",
          "item": pageUrl
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can I keep my tablet if I move to another state?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You may be able to keep the device, but you should update your address and check whether your current provider still serves the new state."
          }
        },
        {
          "@type": "Question",
          "name": "Do some states have their own tablet programs besides Lifeline?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Some states, cities, libraries, schools, housing authorities, and nonprofits run separate digital access programs depending on local funding."
          }
        },
        {
          "@type": "Question",
          "name": "What if my preferred provider does not operate in my state?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Use the USAC Companies Near Me tool to see which approved Lifeline providers serve your ZIP code or state."
          }
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      "url": siteUrl,
      "name": "FreeTablet.click",
      "inLanguage": "en-US"
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Header />

  <main id="main-content" class="w-full flex-1 flex flex-col items-center">

    <!-- ==========================================
         SECTION 1: PREMIUM HERO
    =========================================== -->
    <section class="relative w-full flex flex-col items-center justify-center overflow-hidden bg-[#0f172a] text-white pt-20 pb-24 lg:pt-28 lg:pb-32" style="background-image: radial-gradient(circle at top right, rgba(37, 99, 235, 0.15), transparent 40%), radial-gradient(circle at bottom left, rgba(168, 85, 247, 0.15), transparent 40%);">
      <div class="relative z-10 mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8 text-center">

        <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-semibold text-blue-100 mb-6 shadow-sm">
          <svg class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span>Nationwide Program Directory</span>
        </div>

        <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl text-white mb-6">
          Find Free Government Tablet Programs By <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-blue-100">State</span>
        </h1>

        <p class="text-lg text-blue-100 sm:text-xl leading-relaxed font-medium max-w-3xl mx-auto mb-8">
          Eligibility rules, participating providers, and device inventory vary by location. Use this directory to start with the right state, then move into the eligibility guide, application steps, and provider pages that support the homepage.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/" class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-8 py-4 text-lg font-bold text-white shadow-xl hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 transition-all duration-300 transform hover:-translate-y-1 w-full sm:w-auto">
            Free Government Tablet Guide
          </a>
          <a href="/eligibility" class="inline-flex items-center justify-center rounded-lg border border-white/30 bg-white/5 px-8 py-4 text-lg font-bold text-white hover:bg-white/10 transition-all duration-300 w-full sm:w-auto">
            Check Eligibility
          </a>
        </div>

      </div>
    </section>

    <!-- ==========================================
         SECTION 2: WHY LOCATION MATTERS (INFO BOX)
    =========================================== -->
    <section class="relative w-full py-12 bg-white border-b border-border">
      <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-center shadow-sm">
          <div class="flex-shrink-0 w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-sm">
            <svg class="w-8 h-8 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-primary mb-2">Why Your Location Matters</h2>
            <p class="text-foreground/80 leading-relaxed font-medium">
              While Lifeline is a federal initiative, the specific wireless providers (such as Assurance Wireless or AirTalk Wireless) operate on a state-by-state basis. Many states also offer local digital inclusion grants and broadband support separate from federal funding. Checking state-specific details helps you avoid missing local opportunities.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 2.25: INTERNAL START HERE LINKS
    =========================================== -->
    <section class="relative w-full py-12 bg-white">
      <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-border bg-muted/20 p-6 sm:p-8 shadow-sm">
          <div class="max-w-3xl">
            <h2 class="text-2xl font-bold text-foreground mb-2">Start Here Before You Check Your State</h2>
            <p class="text-foreground/75 leading-relaxed">
              For the safest path, start with the <a href="/" class="font-bold text-primary-light hover:underline">free government tablet guide</a>, confirm your rules on the <a href="/eligibility" class="font-bold text-primary-light hover:underline">eligibility page</a>, then use <a href="/how-to-apply" class="font-bold text-primary-light hover:underline">how to apply</a> and the provider pages to compare your next move.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-6">
            <a href="/" class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <h3 class="font-bold text-foreground mb-1">Homepage Guide</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">Main free tablet overview, program summary, and core internal paths.</p>
            </a>
            <a href="/eligibility" class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <h3 class="font-bold text-foreground mb-1">Eligibility Rules</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">Income limits, approved programs, household rules, and survivor protections.</p>
            </a>
            <a href="/how-to-apply" class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <h3 class="font-bold text-foreground mb-1">Application Steps</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">Use this before you upload documents or choose a provider.</p>
            </a>
            <a href="/assurance-wireless" class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <h3 class="font-bold text-foreground mb-1">Provider Example</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">Start comparing live provider pages while more state pages roll out.</p>
            </a>
          </div>
        </div>
      </div>
    </section>
    <!-- ==========================================
         SECTION 2.5: OFFICIAL RESOURCES (EXTERNAL LINKS ONLY)
    =========================================== -->
    <section class="relative w-full py-12 bg-white">
      <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-border bg-muted/20 p-6 sm:p-8 shadow-sm">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
            <div>
              <h2 class="text-2xl font-bold text-foreground">Official Resources</h2>
              <p class="text-foreground/75 mt-1">Use these official pages for eligibility checks and provider lookup. If you live in Texas or Oregon, application steps may route through state-specific processes.</p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <a
              href="https://www.checklifeline.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors"
            >
              <h3 class="font-bold text-foreground mb-1">National Verifier</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">Official Lifeline eligibility and application portal.</p>
            </a>

            <a
              href="https://www.lifelinesupport.org/companies-near-me/"
              target="_blank"
              rel="noopener noreferrer"
              class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors"
            >
              <h3 class="font-bold text-foreground mb-1">USAC Companies Near Me</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">Find approved Lifeline providers by state and ZIP code.</p>
            </a>

            <a
              href="https://www.fcc.gov/lifeline-consumers"
              target="_blank"
              rel="noopener noreferrer"
              class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors"
            >
              <h3 class="font-bold text-foreground mb-1">FCC Lifeline Info</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">Program rules, consumer protections, and official guidance.</p>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 3: FEATURED STATES
    =========================================== -->
    <section class="relative w-full py-16 lg:py-24 bg-muted/30">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="text-center max-w-3xl mx-auto mb-12">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            High-Demand Service Areas
          </h2>
          <p class="text-lg text-foreground/75 leading-relaxed">
            These states currently feature large provider footprints and strong community support demand.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">

          <!-- California -->
          <div class="bg-white rounded-3xl p-8 border border-border shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary-light/5 rounded-full blur-2xl -mr-10 -mt-10 transition-transform group-hover:scale-150"></div>
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6 relative z-10">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-3 relative z-10">California</h3>
            <p class="text-sm text-foreground/75 leading-relaxed mb-6 flex-grow relative z-10 font-medium">
              California has immense provider coverage and high demand for low-income connectivity. Device inventory moves fast, so provider comparison matters.
            </p>
            <a href="/" class="inline-flex items-center text-primary-light font-bold text-sm group-hover:text-primary transition-colors relative z-10">
              See Free Tablet Guide
              <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
            </a>
          </div>

          <!-- Texas -->
          <div class="bg-white rounded-3xl p-8 border border-border shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary-light/5 rounded-full blur-2xl -mr-10 -mt-10 transition-transform group-hover:scale-150"></div>
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6 relative z-10">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-3 relative z-10">Texas</h3>
            <p class="text-sm text-foreground/75 leading-relaxed mb-6 flex-grow relative z-10 font-medium">
              Texas offers broad coverage, though ZIP-level differences strongly affect provider options. Many applicants qualify through EBT or Medicaid.
            </p>
            <a href="/eligibility" class="inline-flex items-center text-primary-light font-bold text-sm group-hover:text-primary transition-colors relative z-10">
              Check Eligibility Rules
              <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
            </a>
          </div>

          <!-- Florida -->
          <div class="bg-white rounded-3xl p-8 border border-border shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary-light/5 rounded-full blur-2xl -mr-10 -mt-10 transition-transform group-hover:scale-150"></div>
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6 relative z-10">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-3 relative z-10">Florida</h3>
            <p class="text-sm text-foreground/75 leading-relaxed mb-6 flex-grow relative z-10 font-medium">
              Florida sees strong mobile network demand and rotating provider inventory. Compare shipping and co-pay terms carefully.
            </p>
            <a href="/how-to-apply" class="inline-flex items-center text-primary-light font-bold text-sm group-hover:text-primary transition-colors relative z-10">
              See Application Steps
              <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
            </a>
          </div>

          <!-- New York -->
          <div class="bg-white rounded-3xl p-8 border border-border shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary-light/5 rounded-full blur-2xl -mr-10 -mt-10 transition-transform group-hover:scale-150"></div>
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6 relative z-10">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-3 relative z-10">New York</h3>
            <p class="text-sm text-foreground/75 leading-relaxed mb-6 flex-grow relative z-10 font-medium">
              New York residents may find city-funded and nonprofit support options alongside standard provider offers, especially for seniors.
            </p>
            <a href="/assurance-wireless" class="inline-flex items-center text-primary-light font-bold text-sm group-hover:text-primary transition-colors relative z-10">
              View Provider Example
              <svg class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 4: 50-STATE DIRECTORY (A-Z)
    =========================================== -->
    <section class="relative w-full py-16 lg:py-24 bg-white border-t border-border">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">

        <div class="text-center max-w-3xl mx-auto mb-12">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            Comprehensive State Directory (A-Z)
          </h2>
          <p class="text-lg text-foreground/75 leading-relaxed">
            State-specific content is still growing. For now, use this directory as a clean navigation hub, then move into the homepage, eligibility, application, and provider pages for live guidance.
          </p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4">
          {allStates.map((state) => (
            <div
              class="flex items-center justify-between px-4 py-3 bg-muted/30 border border-border rounded-lg text-sm font-semibold text-foreground"
            >
              <span>{state}</span>
              <span class="text-xs font-bold uppercase tracking-wide text-foreground/40">Guide</span>
            </div>
          ))}
        </div>
        <div class="mt-10 rounded-2xl border border-border bg-muted/20 p-6 sm:p-8 shadow-sm">
          <h3 class="text-2xl font-bold text-foreground mb-3">Use These Core Guides While State Pages Expand</h3>
          <p class="text-foreground/75 leading-relaxed mb-6">
            These pages are the safest internal next steps and they also strengthen the main site architecture around free government tablet searches.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/" class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <h4 class="font-bold text-foreground mb-1">Free Government Tablet Guide</h4>
              <p class="text-sm text-foreground/70 leading-relaxed">Main topical hub for free tablet, providers, programs, and safety guidance.</p>
            </a>
            <a href="/eligibility" class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <h4 class="font-bold text-foreground mb-1">Eligibility Guide</h4>
              <p class="text-sm text-foreground/70 leading-relaxed">Best page for income rules, program qualifiers, and household requirements.</p>
            </a>
            <a href="/how-to-apply" class="block rounded-xl border border-border bg-white p-5 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <h4 class="font-bold text-foreground mb-1">How to Apply</h4>
              <p class="text-sm text-foreground/70 leading-relaxed">Use before sending documents or choosing your provider.</p>
            </a>
          </div>
        </div>


      </div>
    </section>

    <!-- ==========================================
         SECTION 5: TRIBAL LANDS BENEFIT
    =========================================== -->
    <section class="relative w-full py-16 bg-[#fff7ed] border-y border-[#ffedd5]">
      <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row gap-8 items-center md:items-start">
          <div class="flex-shrink-0 w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-md">
            <svg class="w-8 h-8 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
