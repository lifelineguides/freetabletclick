---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const pageUrl = "https://freetablet.click/assurance-wireless";
const siteUrl = "https://freetablet.click/";
const pageTitle = "Assurance Wireless Lifeline Review | Phone, Tablet, Eligibility Guide 2026";
const pageDescription =
  "Review Assurance Wireless Lifeline service, phone and device options, eligibility rules, and official next steps. Plan details and availability vary by state and ZIP code.";

const schemaGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": pageTitle,
      "description": pageDescription,
      "isPartOf": { "@id": `${siteUrl}#website` },
      "about": [
        { "@type": "Thing", "name": "Assurance Wireless" },
        { "@type": "Thing", "name": "Lifeline Program" },
        { "@type": "Thing", "name": "Free Government Tablet" }
      ],
      "inLanguage": "en-US"
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Does Assurance Wireless give free tablets?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Assurance Wireless primarily promotes Lifeline phone service. Tablet or other device availability can vary by state, ZIP code, inventory, and current offers."
          }
        },
        {
          "@type": "Question",
          "name": "What network does Assurance Wireless use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Assurance Wireless uses the T-Mobile network for its service, although coverage quality can still vary by device and location."
          }
        },
        {
          "@type": "Question",
          "name": "Can I bring my own phone to Assurance Wireless?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Assurance Wireless offers a bring-your-own-phone option for many compatible devices. Check compatibility before starting enrollment."
          }
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      "url": siteUrl,
      "name": "FreeTablet.click",
      "inLanguage": "en-US"
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
  
  <main id="main-content" class="w-full flex-1 flex flex-col items-center">
    
    <!-- ==========================================
         SECTION 1: PREMIUM HERO
    =========================================== -->
    <section class="relative w-full flex flex-col items-center justify-center overflow-hidden bg-[#0f172a] text-white pt-20 pb-32 lg:pt-28 lg:pb-40" style="background-image: radial-gradient(circle at top right, rgba(37, 99, 235, 0.2), transparent 45%), radial-gradient(circle at bottom left, rgba(168, 85, 247, 0.15), transparent 45%);">
      <div class="relative z-10 mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        
        <!-- Trust Badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-sm font-semibold text-blue-100 mb-6 shadow-sm">
          <svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span>FCC Authorized Lifeline Provider</span>
        </div>

        <!-- H1 Headline -->
        <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl text-white mb-6">
          Assurance Wireless <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-blue-100">Free Tablet & Phone Program</span>
        </h1>
        
        <!-- Subtitle -->
        <p class="text-lg text-blue-100 sm:text-xl leading-relaxed font-medium max-w-3xl mx-auto mb-10">
          Review Assurance Wireless Lifeline service, device options, and application steps. Phone offers are common, while tablet availability and plan details can vary by state, ZIP code, and current inventory.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
          <a href="https://www.assurancewireless.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-8 py-4 text-lg font-bold text-white shadow-xl hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-500 transition-all duration-300 transform hover:-translate-y-1 w-full sm:w-auto group">
            Apply Now on Official Site
            <svg class="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/eligibility" class="inline-flex items-center justify-center rounded-lg border border-white/30 bg-white/5 backdrop-blur-sm px-8 py-4 text-lg font-bold text-white hover:bg-white/10 transition-all duration-300 w-full sm:w-auto">
            Check Eligibility First
          </a>
        </div>

      </div>
    </section>

    <!-- ==========================================
         SECTION 2: QUICK OVERVIEW & INTERNAL SUPPORT
    =========================================== -->
    <section class="relative w-full bg-muted/30 pb-16 lg:pb-24" style="content-visibility: auto;">
      <div class="relative z-20 mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8 -mt-16 sm:-mt-20 mb-8">
        <div class="bg-white rounded-2xl p-6 sm:p-10 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.1)] border border-border">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <span class="text-sm font-bold text-foreground/50 uppercase tracking-wider mb-2 block">Quick Provider Snapshot</span>
              <p class="text-foreground/80 font-medium leading-relaxed">
                Assurance Wireless is a Lifeline provider. Availability, data allowances, device stock, and any low-cost device offers vary by state and ZIP code.
              </p>
            </div>
            <div>
              <span class="text-sm font-bold text-foreground/50 uppercase tracking-wider mb-2 block">Best Next Step</span>
              <p class="text-foreground/80 font-medium leading-relaxed">
                Confirm your eligibility first, then compare Assurance Wireless with other provider pages before you apply on the official site.
              </p>
            </div>
            <div>
              <span class="text-sm font-bold text-foreground/50 uppercase tracking-wider mb-2 block">Useful Internal Links</span>
              <div class="flex flex-wrap gap-2">
                <a href="/" class="px-3 py-2 rounded-lg bg-blue-50 text-primary-light text-sm font-bold hover:bg-blue-100 transition-colors">Homepage</a>
                <a href="/eligibility" class="px-3 py-2 rounded-lg bg-blue-50 text-primary-light text-sm font-bold hover:bg-blue-100 transition-colors">Eligibility</a>
                <a href="/how-to-apply" class="px-3 py-2 rounded-lg bg-blue-50 text-primary-light text-sm font-bold hover:bg-blue-100 transition-colors">How to Apply</a>
                <a href="/states" class="px-3 py-2 rounded-lg bg-blue-50 text-primary-light text-sm font-bold hover:bg-blue-100 transition-colors">States</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 3: WHAT DOES ASSURANCE WIRELESS OFFER
    =========================================== -->
    <section class="relative w-full py-16 bg-white border-t border-border">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            What Does Assurance Wireless Offer?
          </h2>
          <p class="text-lg text-foreground/75 leading-relaxed">
            As a subsidiary of T-Mobile, Assurance Wireless is one of the most prominent Lifeline assistance providers in the United States, bringing robust connectivity features directly to low-income households.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          
          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-primary-light/40 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">Unlimited Texts</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              Stay connected effortlessly. Every Lifeline plan with Assurance Wireless includes unlimited texting, ensuring you can always reach family, employers, and healthcare providers.
            </p>
          </div>

          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-primary-light/40 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">Free Monthly Data</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              Plan data amounts and service details can vary by state offer. Check the official availability page for your ZIP code before relying on any specific allowance.
            </p>
          </div>

          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-primary-light/40 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">Free Smartphone</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              Phone offers are common for qualifying customers, but the exact model and availability depend on state offer terms and current stock.
            </p>
          </div>

          <div class="bg-muted/30 rounded-2xl p-8 border border-border shadow-sm flex flex-col hover:border-primary-light/40 transition-colors relative overflow-hidden">
            <div class="absolute top-0 right-0 bg-orange-100 text-orange-800 text-[10px] font-bold px-3 py-1 rounded-bl-lg uppercase tracking-wider">Subject to Inventory</div>
            <div class="w-12 h-12 rounded-xl bg-blue-50 text-primary-light flex items-center justify-center mb-6 mt-2">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3">Discounted Tablet</h3>
            <p class="text-foreground/75 leading-relaxed text-sm font-medium">
              Assurance Wireless primarily promotes phone service. Other device availability, if offered, can vary by state, inventory, and current promotions, so always confirm the official offer before applying.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 4: HOW TO QUALIFY
    =========================================== -->
    <section class="relative w-full py-16 lg:py-24 bg-slate-50 border-t border-border" style="content-visibility: auto;">
      <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            How to Qualify for Assurance Wireless
          </h2>
          <p class="text-lg text-foreground/75 leading-relaxed">
            Eligibility for Assurance Wireless is strictly dictated by the federal Lifeline program. You can qualify through one of two main pathways:
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          
          <!-- Income Based -->
          <div class="bg-white rounded-2xl border border-border p-8 shadow-sm">
            <div class="flex items-center gap-4 mb-6 border-b border-border pb-4">
              <div class="w-10 h-10 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
                <span class="font-bold text-lg">1</span>
              </div>
              <h3 class="text-xl font-bold text-foreground">Income-Based Rules</h3>
            </div>
            <p class="text-foreground/75 leading-relaxed font-medium mb-6">
              You can qualify if your total household income is at or below <strong>135% of the Federal Poverty Guidelines</strong>.
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Requires proof of income (e.g., prior year's tax return, consecutive pay stubs).
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Income thresholds adjust annually based on household size.
              </li>
            </ul>
          </div>

          <!-- Program Based -->
          <div class="bg-white rounded-2xl border border-border p-8 shadow-sm">
            <div class="flex items-center gap-4 mb-6 border-b border-border pb-4">
              <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center">
                <span class="font-bold text-lg">2</span>
              </div>
              <h3 class="text-xl font-bold text-foreground">Program-Based Rules</h3>
            </div>
            <p class="text-foreground/75 leading-relaxed font-medium mb-6">
              You automatically qualify if you (or a dependent) participate in any of these federal assistance programs:
            </p>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                SNAP (Supplemental Nutrition Assistance Program / EBT)
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Medicaid
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Supplemental Security Income (SSI)
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Veterans Pension and Survivors Benefit
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground/80 font-medium">
                <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                Federal Public Housing Assistance (FPHA)
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 5: OFFICIAL CONTACT INFORMATION
    =========================================== -->
    <section class="relative w-full py-12 lg:py-16 bg-white border-t border-border">
      <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
        
        <div class="bg-blue-600 rounded-3xl p-8 sm:p-10 text-white shadow-xl flex flex-col md:flex-row items-center justify-between gap-8">
          <div class="max-w-lg text-center md:text-left">
            <div class="inline-flex items-center gap-2 rounded-full bg-blue-500/50 px-3 py-1 text-xs font-bold uppercase tracking-wider mb-4">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Official Contact Info
            </div>
            <h2 class="text-2xl sm:text-3xl font-extrabold mb-4">Check Your Application Status</h2>
            <p class="text-blue-100 font-medium leading-relaxed m-0">
              We do not process applications. If you have already applied and need to check your status, track a shipment, or troubleshoot a device, please contact Assurance Wireless directly.
            </p>
          </div>

          <div class="flex flex-col gap-4 w-full md:w-auto shrink-0">
            <a href="tel:18883215880" class="flex items-center justify-center gap-3 bg-white text-blue-900 px-6 py-4 rounded-xl font-bold hover:bg-blue-50 transition-colors shadow-md">
              <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              1-888-321-5880
            </a>
            <a href="https://www.assurancewireless.com/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 bg-blue-700 text-white px-6 py-4 rounded-xl font-bold hover:bg-blue-800 transition-colors shadow-md">
              <svg class="w-5 h-5 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
              assurancewireless.com
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- ==========================================
         SECTION 6: PROVIDER FAQ
    =========================================== -->
    <section class="relative w-full py-16 lg:py-24 bg-muted/30 border-t border-border" style="content-visibility: auto;">
      <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
          <h2 class="text-3xl font-extrabold tracking-tight text-foreground sm:text-4xl mb-4">
            Assurance Wireless FAQ
          </h2>
        </div>

        <div class="space-y-4">
          
          <details class="group bg-white border border-border rounded-xl overflow-hidden shadow-sm [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-foreground hover:bg-muted/50 transition-colors text-lg">
              Does Assurance Wireless give free tablets?
              <span class="transition duration-300 group-open:-rotate-180 text-primary shrink-0 ml-4">
                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="24" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="text-foreground/75 p-6 pt-0 leading-relaxed font-medium border-t border-border mt-2">
              Assurance Wireless mainly promotes Lifeline phone service. Device availability beyond the standard phone offer can vary by state, ZIP code, inventory, and current offer terms, so check the official site before applying.
            </div>
          </details>

          <details class="group bg-white border border-border rounded-xl overflow-hidden shadow-sm [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-foreground hover:bg-muted/50 transition-colors text-lg">
              What network does Assurance Wireless use?
              <span class="transition duration-300 group-open:-rotate-180 text-primary shrink-0 ml-4">
                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="24" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="text-foreground/75 p-6 pt-0 leading-relaxed font-medium border-t border-border mt-2">
              Assurance Wireless uses the T-Mobile network, but actual coverage and device performance can still vary by ZIP code, building conditions, and phone compatibility.
            </div>
          </details>

          <details class="group bg-white border border-border rounded-xl overflow-hidden shadow-sm [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-foreground hover:bg-muted/50 transition-colors text-lg">
              Can I bring my own phone (BYOP)?
              <span class="transition duration-300 group-open:-rotate-180 text-primary shrink-0 ml-4">
                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="24" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
              </span>
            </summary>
            <div class="text-foreground/75 p-6 pt-0 leading-relaxed font-medium border-t border-border mt-2">
              Yes. Assurance Wireless offers a bring-your-own-phone option for many compatible devices. Your phone should be unlocked and compatible with the network before you start enrollment.
            </div>
          </details>

        </div>
      </div>
    </section>

    <!-- ==========================================
         SECTION 7: INTERNAL COMPARISON HUB
    =========================================== -->
    <section class="relative w-full py-12 lg:py-16 bg-white border-t border-border">
      <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="rounded-2xl border border-border bg-muted/20 p-6 sm:p-8">
          <h2 class="text-2xl font-bold text-foreground mb-3">Compare before you apply</h2>
          <p class="text-foreground/75 leading-relaxed mb-6">
            Use Assurance Wireless as one option, not your only option. Compare provider details, check eligibility, and review the homepage guide first so the homepage keeps strong topical support.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/" class="px-4 py-3 rounded-lg bg-blue-50 text-primary-light font-bold hover:bg-blue-100 transition-colors">Free Tablet Homepage</a>
            <a href="/how-to-apply" class="px-4 py-3 rounded-lg bg-blue-50 text-primary-light font-bold hover:bg-blue-100 transition-colors">Application Guide</a>
